<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>SalaryServlet</servlet-name>
        <servlet-class>college.SalaryServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Factor</servlet-name>
        <servlet-class>college.FactorServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FactoServlet</servlet-name>
        <servlet-class>college.FactorialServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>palindromeServlet</servlet-name>
        <servlet-class>college.palindromeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Krishnamurthy</servlet-name>
        <servlet-class>Krishnamurthy</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>KrishnaServlet</servlet-name>
        <servlet-class>college.KrishnaServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FactorServlet</servlet-name>
        <servlet-class>college.FactorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SalaryServlet</servlet-name>
        <url-pattern>/SalaryServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Factor</servlet-name>
        <url-pattern>/Factor</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FactoServlet</servlet-name>
        <url-pattern>/FactoServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>palindromeServlet</servlet-name>
        <url-pattern>/palindromeServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Krishnamurthy</servlet-name>
        <url-pattern>/Krishnamurthy</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>KrishnaServlet</servlet-name>
        <url-pattern>/KrishnaServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FactorServlet</servlet-name>
        <url-pattern>/FactorServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
